# Copy to .env and adjust. All values have sane local defaults in config.py.

# Database: SQLite locally, Postgres (Cloud SQL) in prod.
DB_URL=sqlite:///./orguard.db
# DB_URL=postgresql+psycopg2://user:pass@/orguard?host=/cloudsql/PROJECT:REGION:INSTANCE

# Evidence storage: "local" or "gcs"
STORAGE_BACKEND=local
EVIDENCE_DIR=./evidence
GCS_BUCKET=

# CORS: comma-separated origins allowed to call the API / open WS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Perception config ---
# Detector selection: which model provides instrument classes
SURGICAL_MODEL=doccheck        # doccheck | ultralytics | none
PERSON_MODEL=yolo11n.pt        # ultralytics weights for person detection
MODELS_DIR=./models
DETECT_CONF=0.35               # min confidence to keep a detection
DETECT_EVERY_N=1               # run detector every Nth frame (tracker fills gaps)

# --- Hygiene rule thresholds ---
HYGIENE_MIN_DWELL_SEC=3.0      # min seconds hands must dwell in sink zone
HYGIENE_WINDOW_SEC=300         # look-back window for a valid hygiene event
